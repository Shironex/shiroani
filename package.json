{
  "name": "shiroani",
  "version": "1.2.0",
  "private": true,
  "description": "ShiroAni — Your personal anime browser and tracker",
  "license": "SEE LICENSE IN LICENSE",
  "packageManager": "pnpm@10.9.0",
  "scripts": {
    "dev": "pnpm build:packages && concurrently -k -n web,desktop -c cyan,yellow \"pnpm dev:web\" \"wait-on http://localhost:15174 && pnpm --filter @shiroani/desktop dev\"",
    "dev:debug": "LOG_LEVEL=debug pnpm dev",
    "dev:inspect": "pnpm build:packages && concurrently -k -n web,desktop -c cyan,yellow \"pnpm dev:web\" \"wait-on http://localhost:15174 && pnpm --filter @shiroani/desktop dev:inspect\"",
    "dev:web": "pnpm --filter @shiroani/web dev",
    "dev:landing": "pnpm --filter @shiroani/landing dev",
    "build": "pnpm build:packages && pnpm --filter @shiroani/web build && pnpm --filter @shiroani/desktop build",
    "build:packages": "pnpm --filter @shiroani/shared build && pnpm --filter @shiroani/changelog build",
    "package": "pnpm build && pnpm --filter @shiroani/desktop package",
    "package:win": "pnpm build && pnpm --filter @shiroani/desktop package:win",
    "package:mac": "pnpm build && pnpm --filter @shiroani/desktop package:mac",
    "lint": "eslint .",
    "lint:meta": "tsx tools/lint-meta/cli.ts",
    "new:component": "tsx tools/codegen/new-component.ts",
    "new:feature": "tsx tools/codegen/new-feature.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm build:packages && pnpm -r run test",
    "typecheck": "pnpm build:packages && pnpm --filter @shiroani/web typecheck && pnpm --filter @shiroani/desktop typecheck && pnpm --filter @shiroani/bot typecheck",
    "check:locales": "node scripts/check-locale-parity.mjs",
    "screenshots": "node scripts/screenshot-app.mjs",
    "rebuild": "pnpm --filter @shiroani/desktop rebuild",
    "feed:reset": "node scripts/reset-feed-db.mjs feed",
    "feed:reset:full": "node scripts/reset-feed-db.mjs full",
    "version:patch": "node scripts/bump-version.mjs patch",
    "version:minor": "node scripts/bump-version.mjs minor",
    "version:major": "node scripts/bump-version.mjs major",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=22.22.1",
    "pnpm": ">=9.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.0.1",
    "@eslint/js": "^10.0.1",
    "@shiroani/eslint-plugin-repo": "workspace:*",
    "concurrently": "^10.0.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "playwright": "^1.60.0",
    "prettier": "^3.8.1",
    "tsx": "^4.20.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.60.0",
    "wait-on": "^9.0.10"
  }
}
