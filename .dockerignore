# Version control
.git
.gitignore
.gitattributes

# Dependencies — reinstalled inside the image from pnpm-lock.yaml
**/node_modules
.pnpm-store

# Build outputs — regenerated during the image build
**/dist
**/dist-electron
**/release
**/out
**/build
**/storybook-static
**/*.tsbuildinfo
**/*.node
apps/landing/.astro

# Editor / OS
.vscode
.idea
.DS_Store
Thumbs.db
*.swp
*.swo

# Logs
**/*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Local env (never ship secrets into images)
.env
.env.local
.env.*.local
electron-builder.env

# Test output
coverage
.nyc_output
playwright-report
test-results

# Docs (not needed in runtime images)
docs

# CI configuration
.github

# Docker metadata (not needed inside the image itself)
Dockerfile*
.dockerignore
docker-compose*.yml

# Tool caches / scratch
.cache
.mcp.json
.claude
.planning
.worktrees
shiroani-design
