{
  "name": "@shiroani/desktop",
  "version": "1.2.0",
  "description": "ShiroAni desktop application",
  "author": {
    "name": "Shironex",
    "email": "support@taketach.pl"
  },
  "homepage": "https://github.com/Shironex/shiroani",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "predev": "node scripts/native-build.mjs",
    "dev": "node esbuild.config.mjs && cross-env NODE_ENV=development electron .",
    "dev:inspect": "node esbuild.config.mjs && cross-env NODE_ENV=development electron . --remote-debugging-port=9222 --remote-allow-origins=*",
    "build:dev": "node esbuild.config.mjs",
    "build": "pnpm native:build && node esbuild.config.mjs && node scripts/copy-renderer.mjs",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:watch": "jest --watch",
    "package": "pnpm build && electron-builder",
    "package:win": "pnpm build && electron-builder --win",
    "package:mac": "pnpm build && electron-builder --mac",
    "native:build": "node scripts/native-build.mjs",
    "native:clean": "node-gyp clean",
    "postinstall": "electron-builder install-app-deps",
    "rebuild": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@ghostery/adblocker-electron": "^2.17.3",
    "@ghostery/adblocker-electron-preload": "^2.17.3",
    "@mozilla/readability": "^0.6.0",
    "@nestjs/common": "^11.1.24",
    "@nestjs/core": "^11.1.24",
    "@nestjs/platform-express": "^11.1.24",
    "@nestjs/platform-socket.io": "^11.1.24",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^11.1.24",
    "@shiroani/shared": "workspace:*",
    "@xhayper/discord-rpc": "^1.3.1",
    "better-sqlite3": "^12.9.0",
    "cross-fetch": "^4.1.0",
    "dompurify": "^3.4.11",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "jsdom": "^29.1.1",
    "node-addon-api": "^8.8.0",
    "reflect-metadata": "^0.2.2",
    "rss-parser": "3.13.0",
    "rxjs": "^7.8.2",
    "semver": "^7.8.1",
    "socket.io": "^4.8.3",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@anatine/esbuild-decorators": "^0.2.19",
    "@electron/rebuild": "^4.0.3",
    "@nestjs/testing": "^11.1.24",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.0.1",
    "@types/semver": "^7.7.1",
    "cross-env": "^10.1.0",
    "electron": "^42.0.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.28.1",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.11"
  }
}
