---
import { t, type SupportedLanguage } from '../lib/i18n';

interface Props {
  /** Active SSR language. Defaults to PL; `/en/*` pages pass `lang="en"`. */
  lang?: SupportedLanguage;
}

const { lang = 'pl' } = Astro.props;
const tt = (key: string) => t(key, lang);

const faqs = [
  { qKey: 'faq.q1', aKey: 'faq.a1' },
  { qKey: 'faq.q2', aKey: 'faq.a2' },
  { qKey: 'faq.q3', aKey: 'faq.a3' },
  { qKey: 'faq.q4', aKey: 'faq.a4' },
  { qKey: 'faq.q5', aKey: 'faq.a5' },
  { qKey: 'faq.q6', aKey: 'faq.a6' },
];
---

<section class="faq-wrap">
  <div class="hd">
    <h2><span data-i18n="faq.heading.lead">{tt('faq.heading.lead')}</span><em data-i18n="faq.heading.em">{tt('faq.heading.em')}</em><span data-i18n="faq.heading.tail">{tt('faq.heading.tail')}</span></h2>
    <p data-i18n="faq.sub">{tt('faq.sub')}</p>
  </div>
  <div class="faq-list">
    {faqs.map((f, i) => (
      <details class="faq" open={i === 0}>
        <summary>
          <span class="n">{`Q.${String(i + 1).padStart(2, '0')}`}</span>
          <span data-i18n={f.qKey}>{tt(f.qKey)}</span>
          <span class="plus">+</span>
        </summary>
        <p data-i18n-html={f.aKey} set:html={tt(f.aKey)}></p>
      </details>
    ))}
  </div>
</section>
