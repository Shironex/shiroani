---
import { Image } from 'astro:assets';
import { BUILT_IN_THEME_METADATA } from '@shiroani/shared';
import mascotWave from '../assets/mascot-wave.png';
import { currentVersion, getReleases } from '../lib/releases';
import { t, type SupportedLanguage } from '../lib/i18n';

const themeCount = BUILT_IN_THEME_METADATA.length;

interface Props {
  /** Active SSR language. Defaults to PL (`/` is the canonical PL page);
   *  `/en/*` pages pass `lang="en"` so the HTML ships English before JS runs. */
  lang?: SupportedLanguage;
}

const { lang = 'pl' } = Astro.props;
const tt = (key: string) => t(key, lang);
const version = currentVersion();
// Eyebrow rides the latest changelog headline so it stays accurate
// release-over-release instead of going stale like the previous hardcoded
// "Floating dock now available" copy. Both locales are emitted so the
// in-place language toggle (see BaseLayout) can swap without a navigation.
const latestHeadline = getReleases(lang)[0].title;
const latestHeadlinePl = getReleases('pl')[0].title;
const latestHeadlineEn = getReleases('en')[0].title;

const libraryCards = [
  { cls: 'c1', title: 'Frieren', ep: '8/28', badge: { text: 'ON AIR', cls: 'live' }, progress: 28 },
  { cls: 'c2', title: 'Dandadan', ep: '5/12', badge: { text: 'NEW' }, progress: 42 },
  { cls: 'c3', title: 'Apothecary', ep: '0/13' },
  { cls: 'c4', title: 'Spy×Family', ep: '45/48', badge: { text: 'S2' }, progress: 94 },
  { cls: 'c5', title: 'Bocchi', ep: '4/12', progress: 33 },
  { cls: 'c6', title: 'Oshi no Ko', ep: '9/11', progress: 82 },
];
---

<section class="hero">
  <div class="hero-grid">
    <div>
      <span class="eyebrow"><span class="blip"></span>v{version} · <span data-release-headline data-headline-pl={latestHeadlinePl} data-headline-en={latestHeadlineEn}>{latestHeadline}</span></span>
      <h1>
        <span data-i18n="hero.headline.lead">{tt('hero.headline.lead')}</span>
        <span class="kanji" data-i18n="hero.headline.kanji">{tt('hero.headline.kanji')}</span>
        <mark class="hl" data-i18n="hero.headline.mark">{tt('hero.headline.mark')}</mark><span data-i18n="hero.headline.tail">{tt('hero.headline.tail')}</span>
      </h1>
      <p class="hero-sub">
        <b>ShiroAni</b> <span data-i18n="hero.sub.lead">{tt('hero.sub.lead')}</span>
      </p>
      <div class="hero-ctas">
        <a href="#pobierz" class="btn btn-primary">
          <span data-i18n="hero.cta.download">{tt('hero.cta.download')}</span><span class="os" data-i18n="hero.cta.os">{tt('hero.cta.os')}</span>
        </a>
        <a href="#podglad" class="btn btn-ghost">
          <svg class="ico" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          <span data-i18n="hero.cta.see">{tt('hero.cta.see')}</span>
        </a>
      </div>
      <p class="hero-strip">
        <span><b>{themeCount}</b> <span data-i18n="hero.strip.themes">{tt('hero.strip.themes')}</span></span>
        <span class="dot" aria-hidden="true">·</span>
        <span><b>05</b> <span data-i18n="hero.strip.statuses">{tt('hero.strip.statuses')}</span></span>
        <span class="dot" aria-hidden="true">·</span>
        <span><b data-i18n="hero.strip.adfree">{tt('hero.strip.adfree')}</b></span>
        <span class="dot" aria-hidden="true">·</span>
        <span><b data-i18n="hero.strip.priceValue">{tt('hero.strip.priceValue')}</b> <span data-i18n="hero.strip.price">{tt('hero.strip.price')}</span></span>
      </p>
    </div>

    <div class="mock" aria-hidden="true" inert>
      <div class="mock-bg"></div>
      <div class="mock-titlebar">
        <div class="dots"><span></span><span></span><span></span></div>
        ShiroAni
      </div>
      <div class="mock-app">
        <div class="mock-head">
          <div class="mock-title">
            <div class="ico">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
            </div>
            <div>
              <h4 data-i18n="hero.mock.library">{tt('hero.mock.library')}</h4>
              <small>{libraryCards.length} <span data-i18n="hero.mock.titlesSuffix">{tt('hero.mock.titlesSuffix')}</span></small>
            </div>
          </div>
          <div class="mock-head-btns">
            <span>↓</span><span>↑</span>
            <span>
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M7 14l4-4 4 4 6-6"/></svg>
            </span>
            <span class="view">▦</span><span>☰</span>
          </div>
        </div>
        <div class="mock-search">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          <span data-i18n="hero.mock.search">{tt('hero.mock.search')}</span>
        </div>
        <div class="mock-tabs">
          <span class="on" data-i18n="hero.mock.tab.all">{tt('hero.mock.tab.all')}</span>
          <span data-i18n="hero.mock.tab.watching">{tt('hero.mock.tab.watching')}</span>
          <span data-i18n="hero.mock.tab.completed">{tt('hero.mock.tab.completed')}</span>
          <span data-i18n="hero.mock.tab.planned">{tt('hero.mock.tab.planned')}</span>
          <span data-i18n="hero.mock.tab.paused">{tt('hero.mock.tab.paused')}</span>
          <span data-i18n="hero.mock.tab.dropped">{tt('hero.mock.tab.dropped')}</span>
        </div>
        <div class="lib-grid">
          {libraryCards.map((card) => (
            <div class={`lib-card ${card.cls}`}>
              <div class="cover"></div>
              {card.badge && (
                <span class={`badge ${card.badge.cls ?? ''}`}>{card.badge.text}</span>
              )}
              <div class="meta">
                <span>{card.title}</span>
                <span class="e">{card.ep}</span>
              </div>
              {card.progress !== undefined && (
                <div class="prog" style={`--p:${card.progress}%`}></div>
              )}
            </div>
          ))}
        </div>
      </div>

      <div class="mock-dock">
        <button class="d on" title={tt('hero.dock.library')} data-i18n-title="hero.dock.library" aria-label={tt('hero.dock.library')} data-i18n-aria-label="hero.dock.library">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        </button>
        <button class="d" title={tt('hero.dock.schedule')} data-i18n-title="hero.dock.schedule" aria-label={tt('hero.dock.schedule')} data-i18n-aria-label="hero.dock.schedule">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2"/><path d="M16 2v4M8 2v4M3 10h18"/></svg>
        </button>
        <button class="d" title={tt('hero.dock.diary')} data-i18n-title="hero.dock.diary" aria-label={tt('hero.dock.diary')} data-i18n-aria-label="hero.dock.diary">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4Z"/></svg>
        </button>
        <button class="d" title={tt('hero.dock.browser')} data-i18n-title="hero.dock.browser" aria-label={tt('hero.dock.browser')} data-i18n-aria-label="hero.dock.browser">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M2 12h20M12 2a15 15 0 0 1 4 10 15 15 0 0 1-4 10 15 15 0 0 1-4-10 15 15 0 0 1 4-10z"/></svg>
        </button>
        <span class="sep"></span>
        <button class="d" title={tt('hero.dock.settings')} data-i18n-title="hero.dock.settings" aria-label={tt('hero.dock.settings')} data-i18n-aria-label="hero.dock.settings">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 1 1-4 0v-.09a1.65 1.65 0 0 0-1-1.51 1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 1 1 0-4h.09a1.65 1.65 0 0 0 1.51-1 1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33h.01a1.65 1.65 0 0 0 1-1.51V3a2 2 0 1 1 4 0v.09a1.65 1.65 0 0 0 1 1.51h.01a1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82v.01a1.65 1.65 0 0 0 1.51 1H21a2 2 0 1 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>
        </button>
      </div>

      <Image class="mock-chibi" src={mascotWave} alt="" width={96} height={96} decoding="async" />
    </div>
  </div>
</section>

<script>
  // Keep the hero eyebrow in sync with the in-place language toggle.
  // The headline can't ride the static translations dict because it comes
  // from the changelog package at build time, so we read both locales off
  // data attributes and swap on the lang-change event from BaseLayout.
  function syncEyebrow(lang: string) {
    const el = document.querySelector<HTMLElement>('[data-release-headline]');
    if (!el) return;
    const next = lang === 'en' ? el.dataset.headlineEn : el.dataset.headlinePl;
    if (next) el.textContent = next;
  }

  function init() {
    syncEyebrow(document.documentElement.lang || 'pl');
  }

  document.addEventListener('shiroani:lang-change', (e) => {
    const detail = (e as CustomEvent<{ lang: string }>).detail;
    syncEyebrow(detail?.lang ?? 'pl');
  });

  init();
  document.addEventListener('astro:page-load', init);
</script>
