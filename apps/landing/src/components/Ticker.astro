---
const items = [
  { time: '22:30', title: "Frieren: Beyond Journey's End", ep: 'EP 28' },
  { time: '23:00', title: 'Dandadan', ep: 'EP 12' },
  { time: '23:30', title: 'Apothecary Diaries', ep: 'EP 18' },
  { time: '00:00', title: 'Spy × Family', ep: 'EP 45' },
  { time: '00:30', title: 'Mashle', ep: 'EP 24' },
  { time: '01:00', title: 'Bocchi the Rock!', ep: 'S2 EP 04' },
];
---

<div class="ticker-wrap">
  <div class="ticker">
    {[0, 1].map(() => (
      <>
        <span class="live"><span class="on-air" data-i18n="ticker.onAir">ON&nbsp;AIR</span></span>
        {items.map((it, i) => (
          <>
            <span>
              <span class="time">{it.time}</span>
              {' '}<span class="ttl">{it.title}</span>
              {' '}<span class="ep">{it.ep}</span>
            </span>
            {i < items.length - 1 && <span class="dot">·</span>}
          </>
        ))}
        <span class="dot">·</span>
      </>
    ))}
  </div>
</div>
