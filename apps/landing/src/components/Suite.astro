---
import { currentVersion } from '../lib/releases';
import { t, type SupportedLanguage } from '../lib/i18n';

interface Props {
  /** Active SSR language. Defaults to PL; `/en/*` pages pass `lang="en"`. */
  lang?: SupportedLanguage;
}

const { lang = 'pl' } = Astro.props;
const tt = (key: string) => t(key, lang);
const version = currentVersion();
---

<section class="suite">
  <div class="suite-grid">
    <div class="suite-card self" data-s="shiroani">
      <div class="corner">·</div>
      <div>
        <div class="kanji">白アニ</div>
        <div class="romaji">ShiroAni<small data-i18n="suite.shiroani.role">{tt('suite.shiroani.role')}</small></div>
        <p class="role" data-i18n="suite.shiroani.desc">{tt('suite.shiroani.desc')}</p>
      </div>
      <div class="suite-bottom">
        <span class="here" data-i18n="suite.shiroani.here">{tt('suite.shiroani.here')}</span>
        <span>v{version}</span>
      </div>
    </div>

    <a class="suite-card" data-s="shiranami" href="https://shiranami.app" target="_blank" rel="noopener noreferrer">
      <div class="corner">↗</div>
      <div>
        <div class="kanji">白波</div>
        <div class="romaji">Shiranami<small data-i18n="suite.shiranami.role">{tt('suite.shiranami.role')}</small></div>
        <p class="role" data-i18n="suite.shiranami.desc">{tt('suite.shiranami.desc')}</p>
      </div>
      <div class="suite-bottom">
        <span>shiranami.app</span>
        <span>↗</span>
      </div>
    </a>

    <a class="suite-card" data-s="kireimanga" href="https://kireimanga.app" target="_blank" rel="noopener noreferrer">
      <div class="corner">↗</div>
      <div>
        <div class="kanji">綺麗漫画</div>
        <div class="romaji">KireiManga<small data-i18n="suite.kireimanga.role">{tt('suite.kireimanga.role')}</small></div>
        <p class="role" data-i18n="suite.kireimanga.desc">{tt('suite.kireimanga.desc')}</p>
      </div>
      <div class="suite-bottom">
        <span>kireimanga.app</span>
        <span>↗</span>
      </div>
    </a>
  </div>
</section>
