---
import { currentVersion } from '../lib/releases';

const version = currentVersion();
---

<section class="suite">
  <div class="suite-grid">
    <div class="suite-card self" data-s="shiroani">
      <div class="corner">·</div>
      <div>
        <div class="kanji">白アニ</div>
        <div class="romaji">ShiroAni<small data-i18n="suite.shiroani.role">Tracker anime</small></div>
        <p class="role" data-i18n="suite.shiroani.desc">
          Biblioteka, harmonogram, pamiętnik i wbudowana przeglądarka bez reklam.
        </p>
      </div>
      <div class="suite-bottom">
        <span class="here" data-i18n="suite.shiroani.here">Tutaj jesteś</span>
        <span>v{version}</span>
      </div>
    </div>

    <a class="suite-card" data-s="shiranami" href="https://shiranami.app" target="_blank" rel="noopener noreferrer">
      <div class="corner">↗</div>
      <div>
        <div class="kanji">白波</div>
        <div class="romaji">Shiranami<small data-i18n="suite.shiranami.role">Przystań dla muzyki</small></div>
        <p class="role" data-i18n="suite.shiranami.desc">
          Odtwarzacz z playlistami, który gra w tle, gdy czytasz lub oglądasz.
        </p>
      </div>
      <div class="suite-bottom">
        <span>shiranami.app</span>
        <span>↗</span>
      </div>
    </a>

    <a class="suite-card" data-s="kireimanga" href="https://kireimanga.app" target="_blank" rel="noopener noreferrer">
      <div class="corner">↗</div>
      <div>
        <div class="kanji">綺麗漫画</div>
        <div class="romaji">KireiManga<small data-i18n="suite.kireimanga.role">Czytnik mangi</small></div>
        <p class="role" data-i18n="suite.kireimanga.desc">
          Wygodny czytnik z biblioteką rozdziałów, zakładkami i trybem nocnym.
        </p>
      </div>
      <div class="suite-bottom">
        <span>kireimanga.app</span>
        <span>↗</span>
      </div>
    </a>
  </div>
</section>
