---
import { BUILT_IN_THEME_METADATA, type BuiltInThemeMeta } from '@shiroani/shared';

type Feature = {
  cls: string;
  noKey: string;
  noFallback: string;
  tagKey?: string;
  tagFallback?: string;
  tagOn?: boolean;
  titleKey: string;
  titleFallback: string;
  descKey: string;
  descFallback: string;
  img?: string;
  altKey?: string;
  altFallback?: string;
  w?: number;
  h?: number;
  themes?: readonly BuiltInThemeMeta[];
};

const SHOT = { w: 3420, h: 2214 };
const RPC = { w: 1116, h: 378 };

const features: Feature[] = [
  {
    cls: 'col-7 hl',
    noKey: 'features.01.no',
    noFallback: '№ 01 · BROWSER',
    tagKey: 'features.01.tag',
    tagFallback: 'AD-BLOCK · GHOSTERY',
    tagOn: true,
    titleKey: 'features.01.title',
    titleFallback: 'Wbudowana przeglądarka bez reklam.',
    descKey: 'features.01.desc',
    descFallback:
      'Karty, sesje, zakładki i blokada reklam Ghostery — wszystko w tym samym oknie, w którym oglądasz. Żadnych pop-upów ani przekierowań.',
    img: '/assets/browser_view.webp',
    altKey: 'features.01.alt',
    altFallback: 'Wbudowana przeglądarka',
    ...SHOT,
  },
  {
    cls: 'col-5 hl',
    noKey: 'features.02.no',
    noFallback: '№ 02 · LIBRARY',
    tagKey: 'features.02.tag',
    tagFallback: '5 STATUSÓW',
    titleKey: 'features.02.title',
    titleFallback: 'Biblioteka po Twojemu.',
    descKey: 'features.02.desc',
    descFallback:
      'Oglądane, ukończone, planowane, wstrzymane, porzucone. Filtry, notatki, odcinki.',
    img: '/assets/library_view.webp',
    altKey: 'features.02.alt',
    altFallback: 'Biblioteka anime',
    ...SHOT,
  },
  {
    cls: 'col-8 hl',
    noKey: 'features.03.no',
    noFallback: '№ 03 · SCHEDULE',
    tagKey: 'features.03.tag',
    tagFallback: 'ANILIST · LIVE',
    tagOn: true,
    titleKey: 'features.03.title',
    titleFallback: 'Harmonogram emisji z odliczaniem do premiery.',
    descKey: 'features.03.desc',
    descFallback:
      'Widok tygodniowy, dzienny i tabelaryczny. Dane prosto z AniList. Powiadomienie, gdy wchodzi nowy odcinek.',
    img: '/assets/schedule_view.webp',
    altKey: 'features.03.alt',
    altFallback: 'Harmonogram emisji',
    ...SHOT,
  },
  {
    cls: 'col-4',
    noKey: 'features.04.no',
    noFallback: '№ 04 · DIARY',
    tagKey: 'features.04.tag',
    tagFallback: 'TIPTAP',
    titleKey: 'features.04.title',
    titleFallback: 'Pamiętnik z formatowaniem.',
    descKey: 'features.04.desc',
    descFallback:
      'Zapisuj wrażenia po każdym odcinku: tekst z formatowaniem, obrazki, nagłówki — wszystko lokalnie.',
    img: '/assets/diary_view.webp',
    altKey: 'features.04.alt',
    altFallback: 'Pamiętnik',
    ...SHOT,
  },
  {
    cls: 'col-4',
    noKey: 'features.05.no',
    noFallback: '№ 05 · DISCORD RPC',
    tagKey: 'features.05.tag',
    tagFallback: 'TEMPLATE EDITOR',
    titleKey: 'features.05.title',
    titleFallback: 'Pokaż znajomym, co oglądasz.',
    descKey: 'features.05.desc',
    descFallback:
      'Rich Presence z własnym szablonem. Podgląd na żywo w ustawieniach. Edytujesz tekst, obrazki, akcje.',
    img: '/assets/discord_rpc.webp',
    altKey: 'features.05.alt',
    altFallback: 'Discord Rich Presence',
    ...RPC,
  },
  {
    cls: 'col-4',
    noKey: 'features.06.no',
    noFallback: '№ 06 · NEW TAB',
    titleKey: 'features.06.title',
    titleFallback: 'Ulubione strony pod jednym kliknięciem.',
    descKey: 'features.06.desc',
    descFallback: 'Kafelki szybkiego dostępu. Raz skonfigurujesz, masz na zawsze.',
    img: '/assets/onboarding.webp',
    altKey: 'features.06.alt',
    altFallback: 'Nowa karta',
    ...SHOT,
  },
  {
    cls: 'col-4 ft-themes',
    noKey: 'features.07.no',
    noFallback: '№ 07 · THEMES',
    titleKey: 'features.07.title',
    titleFallback: '17 motywów plus edytor własnych.',
    descKey: 'features.07.desc',
    descFallback:
      '15 ciemnych, 2 jasne, większość inspirowana anime. Wizualny edytor palety, czcionek i tła.',
    themes: BUILT_IN_THEME_METADATA,
  },
  {
    cls: 'col-4',
    noKey: 'features.08.no',
    noFallback: '№ 08 · NOTIFICATIONS',
    titleKey: 'features.08.title',
    titleFallback: 'Nowy odcinek? Jesteś pierwszy.',
    descKey: 'features.08.desc',
    descFallback:
      'Powiadomienia systemowe, gdy tylko któraś seria z biblioteki dostaje nowy odcinek.',
  },
  {
    cls: 'col-4',
    noKey: 'features.09.no',
    noFallback: '№ 09 · IMPORT / EXPORT',
    titleKey: 'features.09.title',
    titleFallback: 'Twoje dane należą do Ciebie.',
    descKey: 'features.09.desc',
    descFallback:
      'Lokalne SQLite. Import i eksport biblioteki i pamiętnika jednym kliknięciem. Bez chmury, bez konta.',
  },
];
---

<section class="features">
  <div class="fgrid">
    {features.map((f) => (
      <article class={`fc ${f.cls}`}>
        <div class="fc-head">
          <span class="no" data-i18n={f.noKey}>{f.noFallback}</span>
          {f.tagFallback && <span class={`tag ${f.tagOn ? 'on' : ''}`} data-i18n={f.tagKey}>{f.tagFallback}</span>}
        </div>
        <h3 data-i18n={f.titleKey}>{f.titleFallback}</h3>
        <p data-i18n={f.descKey}>{f.descFallback}</p>
        {f.img && (
          <div class="fimg">
            <img
              src={f.img}
              alt={f.altFallback}
              data-i18n-alt={f.altKey}
              loading="lazy"
              decoding="async"
              width={f.w}
              height={f.h}
            />
          </div>
        )}
        {f.themes && (
          <div class="fthemes" aria-hidden="true">
            <div class="fthemes-row" data-group="dark">
              {f.themes.filter((t) => t.isDark).map((t) => (
                <div
                  class="fthemes-sw"
                  title={t.label}
                  style={`--sw-bg: oklch(0.12 0.018 300); --sw-fg: ${t.color};`}
                >
                  <span class="fthemes-lbl">{t.label}</span>
                </div>
              ))}
            </div>
            <div class="fthemes-row" data-group="light">
              {f.themes.filter((t) => !t.isDark).map((t) => (
                <div
                  class="fthemes-sw is-light"
                  title={t.label}
                  style={`--sw-bg: oklch(0.97 0.008 80); --sw-fg: ${t.color};`}
                >
                  <span class="fthemes-lbl">{t.label}</span>
                </div>
              ))}
            </div>
          </div>
        )}
      </article>
    ))}
  </div>
</section>
