---
import '../styles/global.css';
import { Font } from 'astro:assets';
import { translations, type SupportedLanguage } from '../lib/i18n';

interface Props {
  title: string;
  description?: string;
  titleKey?: string;
  descriptionKey?: string;
  ogTitleKey?: string;
  lang?: SupportedLanguage;
  /** Per-page Open Graph image override (absolute path). Falls back to /og-default.png. */
  ogImage?: string;
  /** Emit `<meta name="robots" content="noindex">` for non-indexable pages (e.g. 404). */
  noindex?: boolean;
}

const {
  title,
  description,
  titleKey,
  descriptionKey,
  ogTitleKey = 'meta.home.ogTitle',
  lang = 'pl',
  ogImage: ogImageProp,
  noindex = false,
} = Astro.props;

const dict = translations[lang];
const resolvedTitle = (titleKey && dict[titleKey]) || title;
const resolvedDescription =
  (descriptionKey && dict[descriptionKey]) ||
  description ||
  dict['meta.home.description'];
const resolvedOgTitle = dict[ogTitleKey] ?? resolvedTitle;

const ogImage = new URL(ogImageProp ?? '/og-default.png', Astro.site);
// Organization.logo wants a square mark; the 1200×630 OG banner is reused for
// the OG/SoftwareApplication `image` fields instead.
const logoUrl = new URL('/logo-512.png', Astro.site).href;
const ogImageUrl = ogImage.href;

// Structured data (JSON-LD). Organization + SoftwareApplication + WebSite as a
// single @graph, emitted on every page. Absolute URLs are required by schema.org.
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://shiroani.app/#organization',
      name: 'ShiroAni',
      description: resolvedDescription,
      url: 'https://shiroani.app',
      logo: {
        '@type': 'ImageObject',
        url: logoUrl,
        width: 512,
        height: 512,
      },
      sameAs: ['https://github.com/Shironex/shiroani'],
    },
    {
      '@type': 'SoftwareApplication',
      '@id': 'https://shiroani.app/#software',
      name: 'ShiroAni',
      description: resolvedDescription,
      url: 'https://shiroani.app',
      applicationCategory: 'MultimediaApplication',
      operatingSystem: ['Windows 10', 'Windows 11', 'macOS 11+'],
      offers: {
        '@type': 'Offer',
        price: '0',
        priceCurrency: 'USD',
      },
      image: ogImageUrl,
      creator: {
        '@type': 'Organization',
        '@id': 'https://shiroani.app/#organization',
      },
    },
    {
      '@type': 'WebSite',
      '@id': 'https://shiroani.app/#website',
      name: 'ShiroAni',
      url: 'https://shiroani.app',
      inLanguage: ['pl', 'en'],
    },
  ],
};

// Build the PL/EN URL pair for this page so every page emits a self-canonical
// link plus reciprocal hreflang alternates. The route convention is `/foo` for
// PL (the default locale) and `/en/foo` for EN; strip/prepend the `/en` segment
// to derive the counterpart. `x-default` points at the PL page.
// `build.format: 'file'` yields pathnames like `/changelog.html` and
// `/index.html`; normalize to a clean, slash-less path so canonical + hreflang
// match the sitemap and the no-trailing-slash URLs the host serves.
let path =
  Astro.url.pathname.replace(/\.html$/, '').replace(/\/index$/, '').replace(/\/$/, '') || '/';
const isEnHome = path === '/en';
const plPath = isEnHome ? '/' : path.replace(/^\/en(?=\/)/, '') || '/';
const enPath = plPath === '/' ? '/en' : `/en${plPath}`;
const plUrl = new URL(plPath, Astro.site);
const enUrl = new URL(enPath, Astro.site);
const canonicalUrl = lang === 'en' ? enUrl : plUrl;
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="color-scheme" content="dark" />
<!-- theme-color is the hex of the `--bg` token (oklch(0.12 0.018 300)). -->
<meta name="theme-color" content="#07050b" />
<link rel="icon" type="image/png" href="/favicon.png" />
<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
<link rel="manifest" href="/manifest.webmanifest" />
<link rel="sitemap" href="/sitemap-index.xml" />
{noindex && <meta name="robots" content="noindex" />}

<link rel="canonical" href={canonicalUrl} />
<link rel="alternate" hreflang="pl" href={plUrl} />
<link rel="alternate" hreflang="en" href={enUrl} />
<link rel="alternate" hreflang="x-default" href={plUrl} />

{/*
  Self-hosted fonts (Astro Fonts API), served from /_astro/fonts with subsetting
  preserved per astro.config.mjs. Deliberately NO `preload` prop here: the
  provider mislabels the JP unicode-range chunks as subset "latin", so any
  subset/weight preload filter floods the head with 100+ CJK chunk preloads.
  Instead the `font-preload-fix` integration in astro.config.mjs injects
  precise preload links per page (latin faces of the above-the-fold fonts) by
  parsing the inlined @font-face CSS after the build.
*/}
<Font cssVariable="--font-display" />
<Font cssVariable="--font-body" />
<Font cssVariable="--font-mono" />
<Font cssVariable="--font-mincho" />

<title data-i18n-text={titleKey}>{resolvedTitle}</title>
<meta name="description" content={resolvedDescription} data-i18n-content={descriptionKey} />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:locale" content={lang === 'pl' ? 'pl_PL' : 'en_US'} />
<meta property="og:title" content={resolvedOgTitle} data-i18n-content={ogTitleKey} />
<meta property="og:description" content={resolvedDescription} data-i18n-content={descriptionKey} />
<meta property="og:image" content={ogImage} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={resolvedOgTitle} data-i18n-content={ogTitleKey} />
<meta name="twitter:description" content={resolvedDescription} data-i18n-content={descriptionKey} />
<meta name="twitter:image" content={ogImage} />

<!-- Structured data -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
