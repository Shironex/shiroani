---
import '../styles/global.css';
import { translations, type SupportedLanguage } from '../lib/i18n';

interface Props {
  title: string;
  description?: string;
  titleKey?: string;
  descriptionKey?: string;
  ogTitleKey?: string;
  lang?: SupportedLanguage;
  /** Per-page Open Graph image override (absolute path). Falls back to /og-default.png. */
  ogImage?: string;
  /** Emit `<meta name="robots" content="noindex">` for non-indexable pages (e.g. 404). */
  noindex?: boolean;
}

const {
  title,
  description,
  titleKey,
  descriptionKey,
  ogTitleKey = 'meta.home.ogTitle',
  lang = 'pl',
  ogImage: ogImageProp,
  noindex = false,
} = Astro.props;

const dict = translations[lang];
const resolvedTitle = (titleKey && dict[titleKey]) || title;
const resolvedDescription =
  (descriptionKey && dict[descriptionKey]) ||
  description ||
  dict['meta.home.description'];
const resolvedOgTitle = dict[ogTitleKey] ?? resolvedTitle;

const ogImage = new URL(ogImageProp ?? '/og-default.png', Astro.site);
const logoUrl = new URL('/og-default.png', Astro.site).href;

// Structured data (JSON-LD). Organization + SoftwareApplication + WebSite as a
// single @graph, emitted on every page. Absolute URLs are required by schema.org.
const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': 'https://shiroani.app/#organization',
      name: 'ShiroAni',
      description: resolvedDescription,
      url: 'https://shiroani.app',
      logo: {
        '@type': 'ImageObject',
        url: logoUrl,
        width: 1200,
        height: 630,
      },
      sameAs: ['https://github.com/Shironex/shiroani', 'https://discord.gg/M3ujRdUJpn'],
    },
    {
      '@type': 'SoftwareApplication',
      '@id': 'https://shiroani.app/#software',
      name: 'ShiroAni',
      description:
        'ShiroAni is a desktop application: an ad-free browser, library, airing schedule, and diary. Your whole anime shelf in one cozy window.',
      url: 'https://shiroani.app',
      applicationCategory: 'MultimediaApplication',
      operatingSystem: ['Windows 10', 'Windows 11', 'macOS 11+'],
      offers: {
        '@type': 'Offer',
        price: '0',
        priceCurrency: 'USD',
      },
      image: logoUrl,
      creator: {
        '@type': 'Organization',
        '@id': 'https://shiroani.app/#organization',
      },
    },
    {
      '@type': 'WebSite',
      '@id': 'https://shiroani.app/#website',
      name: 'ShiroAni',
      url: 'https://shiroani.app',
      inLanguage: ['pl', 'en'],
    },
  ],
};

// Build the PL/EN URL pair for this page so every page emits a self-canonical
// link plus reciprocal hreflang alternates. The route convention is `/foo` for
// PL (the default locale) and `/en/foo` for EN; strip/prepend the `/en` segment
// to derive the counterpart. `x-default` points at the PL page.
const path = Astro.url.pathname;
const plPath = path === '/en' || path === '/en/' ? '/' : path.replace(/^\/en(?=\/)/, '');
const enPath = plPath === '/' ? '/en/' : `/en${plPath}`;
const plUrl = new URL(plPath, Astro.site);
const enUrl = new URL(enPath, Astro.site);
const canonicalUrl = lang === 'en' ? enUrl : plUrl;
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<meta name="color-scheme" content="dark" />
<link rel="icon" type="image/png" href="/favicon.png" />
<link rel="sitemap" href="/sitemap-index.xml" />
{noindex && <meta name="robots" content="noindex" />}

<link rel="canonical" href={canonicalUrl} />
<link rel="alternate" hreflang="pl" href={plUrl} />
<link rel="alternate" hreflang="en" href={enUrl} />
<link rel="alternate" hreflang="x-default" href={plUrl} />

<!-- Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Zen+Kaku+Gothic+New:wght@400;500;700;900&family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&family=JetBrains+Mono:wght@400;500;600&family=Shippori+Mincho:wght@500;700;800&display=swap"
  media="print"
  onload="this.media='all'"
/>
<noscript>
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Zen+Kaku+Gothic+New:wght@400;500;700;900&family=DM+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&family=JetBrains+Mono:wght@400;500;600&family=Shippori+Mincho:wght@500;700;800&display=swap"
  />
</noscript>

<title data-i18n-text={titleKey}>{resolvedTitle}</title>
<meta name="description" content={resolvedDescription} data-i18n-content={descriptionKey} />

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:locale" content={lang === 'pl' ? 'pl_PL' : 'en_US'} />
<meta property="og:title" content={resolvedOgTitle} data-i18n-content={ogTitleKey} />
<meta property="og:description" content={resolvedDescription} data-i18n-content={descriptionKey} />
<meta property="og:image" content={ogImage} />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={resolvedOgTitle} data-i18n-content={ogTitleKey} />
<meta name="twitter:description" content={resolvedDescription} data-i18n-content={descriptionKey} />
<meta name="twitter:image" content={ogImage} />

<!-- Structured data -->
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
