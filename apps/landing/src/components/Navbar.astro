---
import { currentVersion } from '../lib/releases';

interface Props {
  activeHref?: string;
}

const { activeHref } = Astro.props;
const version = currentVersion();

const links = [
  { num: '01', label: 'Funkcje', href: '/#funkcje', i18nKey: 'nav.features' },
  { num: '02', label: 'Podgląd', href: '/#podglad', i18nKey: 'nav.preview' },
  { num: '03', label: 'Rodzina', href: '/#suite', i18nKey: 'nav.suite' },
  { num: '04', label: 'Pobierz', href: '/#pobierz', i18nKey: 'nav.download' },
  { num: '05', label: 'Zmiany', href: '/changelog', i18nKey: 'nav.changelog' },
];
---

<nav class="nav" aria-label="Nawigacja główna" data-i18n-aria-label="nav.primary">
  <div class="nav-inner">
    <a class="logo" href="/">
      <span class="mark"><img src="/assets/mascot-wave.png" alt="" width="44" height="44" decoding="async" /></span>
      <span class="name">ShiroAni<small>SHIRO·ANI · v{version}</small></span>
    </a>
    <div class="nav-links">
      {links.map((l) => (
        <a href={l.href} class={activeHref === l.href ? 'on' : undefined}>
          <span class="num">{l.num}</span><span data-i18n={l.i18nKey}>{l.label}</span>
        </a>
      ))}
    </div>
    <div class="nav-right">
      <a class="nav-gh" href="https://github.com/Shironex/shiroani" aria-label="GitHub" data-i18n-aria-label="nav.github" target="_blank" rel="noopener noreferrer">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.4 0 0 5.4 0 12c0 5.3 3.4 9.8 8.2 11.4.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.5-1.4-1.3-1.8-1.3-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2 1-.3 2-.4 3-.4s2 .1 3 .4c2.3-1.5 3.3-1.2 3.3-1.2.7 1.7.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6C20.6 21.8 24 17.3 24 12c0-6.6-5.4-12-12-12z"/>
        </svg>
      </a>
      <button
        class="lang-toggle"
        type="button"
        data-lang-toggle
        aria-label="Przełącz na polski"
      >PL</button>
      <a class="nav-cta" href="/download"><span data-i18n="nav.cta">Pobierz</span> <span aria-hidden="true">↗</span></a>
      <button class="nav-burger" type="button" aria-label="Menu" data-i18n-aria-label="nav.toggleMenu" aria-expanded="false" aria-controls="nav-mobile">
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
        <span aria-hidden="true"></span>
      </button>
    </div>
  </div>
  <div class="nav-mobile" id="nav-mobile" hidden>
    {links.map((l) => (
      <a href={l.href} class={activeHref === l.href ? 'on' : undefined}>
        <span class="num">{l.num}</span><span data-i18n={l.i18nKey}>{l.label}</span>
      </a>
    ))}
  </div>
</nav>

<style>
  .lang-toggle {
    height: 38px;
    min-width: 44px;
    padding: 0 12px;
    border-radius: 10px;
    background: var(--bg-3);
    border: 1px solid var(--hairline);
    color: var(--text-2);
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    cursor: pointer;
    transition: background 0.2s, color 0.2s, border-color 0.2s;
  }
  .lang-toggle:hover {
    background: var(--bg-4);
    color: var(--text);
    border-color: oklch(from var(--accent) l c h / 0.4);
  }
  .lang-toggle:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
</style>

<script>
  const burger = document.querySelector<HTMLButtonElement>('.nav-burger');
  const menu = document.getElementById('nav-mobile');
  if (burger && menu) {
    const setOpen = (open: boolean) => {
      burger.setAttribute('aria-expanded', String(open));
      menu.toggleAttribute('hidden', !open);
      document.documentElement.classList.toggle('nav-open', open);
    };
    burger.addEventListener('click', () => {
      setOpen(burger.getAttribute('aria-expanded') !== 'true');
    });
    menu.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      if (target.closest('a')) setOpen(false);
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && burger.getAttribute('aria-expanded') === 'true') {
        setOpen(false);
        burger.focus();
      }
    });
  }
</script>
