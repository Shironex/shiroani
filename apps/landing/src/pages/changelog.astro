---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import ChangelogPage from '../components/ChangelogPage.astro';
import { Footer } from '../components/Footer';

const lang = 'pl';
---

<BaseLayout
  title="Lista zmian · ShiroAni"
  description="Historia zmian w ShiroAni — funkcja po funkcji, poprawka po poprawce."
  titleKey="meta.changelog.title"
  descriptionKey="meta.changelog.description"
  lang={lang}
>
  <Navbar activeHref="/changelog" lang={lang} />
  <main id="main">
    <ChangelogPage lang={lang} />
  </main>
  <Footer client:visible lang={lang} />
</BaseLayout>
