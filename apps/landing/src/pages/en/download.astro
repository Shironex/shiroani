---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import { DownloadPage } from '../../components/DownloadPage';
import { Footer } from '../../components/Footer';

const lang = 'en';
---

<BaseLayout
  title="Download · ShiroAni"
  description="Download the latest ShiroAni — anime browser & tracker. Windows and macOS."
  titleKey="meta.download.title"
  descriptionKey="meta.download.description"
  lang={lang}
>
  <Navbar activeHref="/#pobierz" lang={lang} />
  <main id="main" class="dlp-wrap">
    <DownloadPage client:load lang={lang} />
  </main>
  <Footer client:visible lang={lang} />
</BaseLayout>
