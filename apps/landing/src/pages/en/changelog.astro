---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import ChangelogPage from '../../components/ChangelogPage.astro';
import { Footer } from '../../components/Footer';

const lang = 'en';
---

<BaseLayout
  title="Changelog · ShiroAni"
  description="ShiroAni release history — feature by feature, fix by fix."
  titleKey="meta.changelog.title"
  descriptionKey="meta.changelog.description"
  lang={lang}
>
  <Navbar activeHref="/changelog" lang={lang} />
  <main id="main">
    <ChangelogPage lang={lang} />
  </main>
  <Footer client:visible lang={lang} />
</BaseLayout>
