---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';
import ChangelogPage from '../../components/ChangelogPage.astro';
import { Footer } from '../../components/Footer';
---

<BaseLayout
  title="Changelog · ShiroAni"
  description="ShiroAni release history — feature by feature, fix by fix."
  titleKey="meta.changelog.title"
  descriptionKey="meta.changelog.description"
  lang="en"
>
  <Navbar activeHref="/changelog" />
  <main id="main">
    <ChangelogPage />
  </main>
  <Footer client:visible />
</BaseLayout>
