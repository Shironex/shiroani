---
import BaseHead from '../components/BaseHead.astro';
import { LANGUAGE_STORAGE_KEY, SUPPORTED_LANGUAGES } from '../lib/i18n';
import type { SupportedLanguage } from '../lib/i18n';

interface Props {
  title: string;
  description?: string;
  titleKey?: string;
  descriptionKey?: string;
  lang?: SupportedLanguage;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  titleKey,
  descriptionKey,
  lang = 'pl',
  ogImage,
  noindex,
} = Astro.props;
---

<!doctype html>
<html lang={lang} data-theme="plum">
  <head>
    <BaseHead
      title={title}
      description={description}
      titleKey={titleKey}
      descriptionKey={descriptionKey}
      lang={lang}
      ogImage={ogImage}
      noindex={noindex}
    />
    <!--
      Anti-FOUC gate. A returning EN visitor landing on a PL-SSR route (`/`)
      would otherwise see a flash of Polish before the deferred swap script
      runs. This blocking script (before first paint) checks the stored
      preference against the SSR `<html lang>` and, only on a mismatch, hides
      the body until the swap completes. Failure-safe: it is a no-op when the
      languages already agree, and a 300 ms timeout reveals the body even if
      the module swap never runs (JS error, slow chunk) so the page can never
      stay blank.
    -->
    <style>
      html.lang-pending body {
        visibility: hidden;
      }
    </style>
    <script is:inline define:vars={{ storageKey: LANGUAGE_STORAGE_KEY, supported: SUPPORTED_LANGUAGES }}>
      (function () {
        try {
          var stored = localStorage.getItem(storageKey);
          var ssr = document.documentElement.lang;
          if (
            stored &&
            stored !== ssr &&
            supported.indexOf(stored) !== -1 &&
            supported.indexOf(ssr) !== -1
          ) {
            document.documentElement.classList.add('lang-pending');
            window.setTimeout(function () {
              document.documentElement.classList.remove('lang-pending');
            }, 300);
          }
        } catch (e) {
          /* localStorage unavailable (private mode) — no gate, no risk */
        }
      })();
    </script>
  </head>
  <body>
    <a href="#main" class="skip-link" data-i18n="layout.skipToContent">Skip to content</a>
    <div class="atm" aria-hidden="true"></div>
    <div class="grain" aria-hidden="true"></div>
    <slot />

    <script>
      // Inline dictionary swap. Values are author-controlled build-time strings
      // (not user input), so direct innerHTML assignments are safe here.
      import {
        translations,
        DEFAULT_LANGUAGE,
        LANGUAGE_STORAGE_KEY,
        isSupportedLanguage,
        type SupportedLanguage,
      } from '../lib/i18n';

      type LandingWindow = Window & {
        __shiroaniLandingTranslations?: Record<SupportedLanguage, Record<string, string>>;
        __shiroaniLandingLang?: SupportedLanguage;
      };
      const landingWindow = window as LandingWindow;
      landingWindow.__shiroaniLandingTranslations = translations;

      // Pairs of [pl-route, en-route] that have dedicated SSR locale siblings.
      const localeRoutes: Array<[string, string]> = [
        ['/changelog', '/en/changelog'],
        ['/download', '/en/download'],
      ];

      function getStoredLang(): SupportedLanguage {
        try {
          const stored = localStorage.getItem(LANGUAGE_STORAGE_KEY);
          if (isSupportedLanguage(stored)) return stored;
        } catch {
          /* ignore — localStorage may be unavailable in private mode */
        }
        // First-visit fallback: trust the SSR `<html lang>` the page was
        // rendered with. The route already chose the language (`/` → pl,
        // `/en/` → en), so overwriting it from a hardcoded default would
        // flash the wrong language on first paint.
        const ssrLang = document.documentElement.lang;
        return isSupportedLanguage(ssrLang) ? ssrLang : DEFAULT_LANGUAGE;
      }

      function rewriteLocalizedLinks(lang: SupportedLanguage) {
        document.querySelectorAll<HTMLAnchorElement>('a[href]').forEach((a) => {
          // Only rewrite same-origin anchors.
          if (a.origin !== location.origin) return;
          const path = a.pathname;
          for (const [pl, en] of localeRoutes) {
            if (lang === 'en' && path === pl) {
              a.href = en;
              break;
            }
            if (lang !== 'en' && path === en) {
              a.href = pl;
              break;
            }
          }
        });

        // The home route has no localeRoutes entry because `/` and `/en/` are
        // the locale roots, not sibling sub-pages. Anchors tagged
        // `data-locale-home` (e.g. the 404 "back home" CTA, which is SSR'd in
        // Polish) get their href pointed at the matching locale root.
        document
          .querySelectorAll<HTMLAnchorElement>('a[data-locale-home]')
          .forEach((a) => {
            a.href = lang === 'en' ? '/en/' : '/';
          });
      }

      function applyTranslations(lang: SupportedLanguage) {
        const dict = translations[lang];
        if (!dict) return;

        document.documentElement.lang = lang;
        landingWindow.__shiroaniLandingLang = lang;

        document.querySelectorAll<HTMLElement>('[data-i18n]').forEach((el) => {
          const key = el.dataset.i18n;
          if (key && dict[key] != null) el.textContent = dict[key];
        });

        document.querySelectorAll<HTMLElement>('[data-i18n-html]').forEach((el) => {
          const key = el.dataset.i18nHtml;
          if (key && dict[key] != null) {
            // Trusted build-time string from the dictionary; safe to inject.
            el.innerHTML = dict[key];
          }
        });

        document.querySelectorAll<HTMLElement>('[data-i18n-alt]').forEach((el) => {
          const key = el.dataset.i18nAlt;
          if (key && dict[key] != null) el.setAttribute('alt', dict[key]);
        });

        document.querySelectorAll<HTMLElement>('[data-i18n-aria-label]').forEach((el) => {
          const key = el.dataset.i18nAriaLabel;
          if (key && dict[key] != null) el.setAttribute('aria-label', dict[key]);
        });

        document.querySelectorAll<HTMLElement>('[data-i18n-title]').forEach((el) => {
          const key = el.dataset.i18nTitle;
          if (key && dict[key] != null) el.setAttribute('title', dict[key]);
        });

        document.querySelectorAll<HTMLMetaElement>('meta[data-i18n-content]').forEach((el) => {
          const key = el.dataset.i18nContent;
          if (key && dict[key] != null) el.setAttribute('content', dict[key]);
        });

        const titleEl = document.querySelector<HTMLTitleElement>('title[data-i18n-text]');
        if (titleEl) {
          const key = titleEl.dataset.i18nText;
          if (key && dict[key] != null) {
            titleEl.textContent = dict[key];
            document.title = dict[key];
          }
        }

        document.querySelectorAll<HTMLButtonElement>('[data-lang-toggle]').forEach((btn) => {
          const visible = lang === 'en' ? 'PL' : 'EN';
          btn.textContent = visible;
          const nextKey = lang === 'en' ? 'nav.switchLanguageToPl' : 'nav.switchLanguageToEn';
          // Accessible name must contain the visible text (WCAG 2.5.3).
          if (dict[nextKey] != null) btn.setAttribute('aria-label', `${visible} — ${dict[nextKey]}`);
        });

        rewriteLocalizedLinks(lang);

        // Reveal the body now that the swap is done — see the anti-FOUC gate
        // in <head>. Removing it is idempotent and harmless when never set.
        document.documentElement.classList.remove('lang-pending');

        document.dispatchEvent(new CustomEvent('shiroani:lang-change', { detail: { lang } }));
      }

      function initI18n() {
        applyTranslations(getStoredLang());

        document.querySelectorAll<HTMLButtonElement>('[data-lang-toggle]').forEach((btn) => {
          btn.addEventListener('click', () => {
            const current = getStoredLang();
            const next: SupportedLanguage = current === 'en' ? 'pl' : 'en';
            try {
              localStorage.setItem(LANGUAGE_STORAGE_KEY, next);
            } catch {
              /* ignore */
            }

            // Routes that have a dedicated locale sibling must navigate so
            // their SSR-rendered content (release cards, etc.) re-renders in
            // the chosen language. The in-place swap can't reach plain-text
            // nodes that carry no data-i18n hook.
            const { pathname } = location;
            for (const [pl, en] of localeRoutes) {
              if (next === 'en' && pathname === pl) {
                location.assign(en);
                return;
              }
              if (next === 'pl' && pathname === en) {
                location.assign(pl);
                return;
              }
            }

            applyTranslations(next);
          });
        });
      }

      initI18n();
      document.addEventListener('astro:page-load', initI18n);
    </script>
  </body>
</html>
