{
  "name": "@shiroani/shared",
  "version": "1.0.0",
  "private": true,
  "description": "ShiroAni shared types and utilities",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build --clean && tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.3",
    "typescript": "^5.9.3",
    "vitest": "^4.1.7"
  }
}
